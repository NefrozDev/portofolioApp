{
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@common/*": ["../Common/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "../Common/**/*.ts",
    "../Common/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
